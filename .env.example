# Arcane City API
ARCANE_CITY_API_URL=https://arcane.city
ARCANE_CITY_USERNAME=your_username
ARCANE_CITY_PASSWORD=your_password

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override for development/staging
# ARCANE_CITY_API_URL=https://dev.arcane.city

# Reddit (script app — password OAuth2 flow)
# Create your app at: https://www.reddit.com/prefs/apps (choose "script" type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=arcane-city-admin:v1.0 (by u/your_username)
REDDIT_DEFAULT_SUBREDDITS=pittsburgh,pittsburghmusic
